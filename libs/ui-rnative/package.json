{
  "name": "@ledgerhq/lumen-ui-rnative",
  "version": "0.1.16",
  "license": "Apache-2.0",
  "keywords": [
    "react-native",
    "ui",
    "components",
    "design-system",
    "mobile"
  ],
  "sideEffects": false,
  "type": "module",
  "react-native": "./src/index.ts",
  "main": "./dist/module/index.js",
  "module": "./dist/module/index.js",
  "types": "./dist/typescript/src/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "react-native": "./src/index.ts",
      "types": "./dist/typescript/src/index.d.ts",
      "import": "./dist/module/index.js",
      "default": "./dist/module/index.js"
    },
    "./symbols": {
      "react-native": "./src/lib/Symbols/index.ts",
      "types": "./dist/typescript/src/lib/Symbols/index.d.ts",
      "import": "./dist/module/lib/Symbols/index.js",
      "default": "./dist/module/lib/Symbols/index.js"
    },
    "./styles": {
      "react-native": "./src/styles/index.ts",
      "types": "./dist/typescript/src/styles/index.d.ts",
      "import": "./dist/module/styles/index.js",
      "default": "./dist/module/styles/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@ledgerhq/lumen-utils-shared": "0.1.2",
    "i18next": "^23.7.0",
    "react-i18next": "^14.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0"
  },
  "peerDependencies": {
    "@types/react": "^19.0.0",
    "@gorhom/bottom-sheet": "^5.0.0",
    "@ledgerhq/lumen-design-core": "0.1.8",
    "react": "^19.0.0",
    "react-native": "~0.79.7",
    "react-native-reanimated": "^4.1.0",
    "react-native-safe-area-context": "^4.0.0 || ^5.0.0",
    "react-native-svg": "^15.0.0",
    "@sbaiahmed1/react-native-blur": "^4.5.5",
    "expo": ">=53.0.0",
    "expo-haptics": "~14.1.4"
  },
  "nx": {
    "tags": [
      "scope:react-native",
      "type:ui"
    ]
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "dist",
    "targets": [
      [
        "module",
        {
          "esm": true,
          "configFile": "./babel.config.bob.cjs"
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.lib.json"
        }
      ]
    ]
  }
}
