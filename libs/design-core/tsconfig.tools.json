{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "outDir": "out-tsc/tools",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ]
  },
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.js",
    "src/**/*.test.tsx",
    "src/**/*.test.jsx"
  ],
  "include": [
    "automations/**/*.ts",
    "tools/**/*.ts",
    "vitest.config.ts",
  ],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ],
  "files": [
    "../../node_modules/@nx/react/typings/styled-jsx.d.ts",
    "../../node_modules/@nx/react/typings/cssmodule.d.ts",
    "../../node_modules/@nx/react/typings/image.d.ts"
  ]
}